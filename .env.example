# =============================================
# KABU MARKET — Environment Variables
# =============================================
# Copy this to .env.local for development
# Add all of these in Vercel → Project → Settings → Environment Variables

# --- Supabase (required) ---
# Get these from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- NewsAPI (required for real news) ---
# Free at newsapi.org/register (100 req/day)
NEWSAPI_KEY=your-newsapi-key-here

# --- Alpha Vantage (required for real stock prices) ---
# Free at alphavantage.co/support/#api-key (25 req/day)
ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here

# --- Security ---
# Vercel automatically sets CRON_SECRET for cron jobs (no action needed)
# Optionally set this to protect the manual trigger endpoint:
UPDATE_SECRET=your-random-secret-here
